{
  "name": "json-build",
  "version": "1.2.0",
  "description": "A CLI/GUI tool to pack project files into JSON and rebuild from JSON",
  "main": "electron/main.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "json-build": "./bin/cli.js"
  },
  "scripts": {
    "test": "node test/test.js",
    "pack": "node bin/cli.js pack",
    "rebuild": "node bin/cli.js rebuild",
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [
    "cli",
    "gui",
    "json",
    "pack",
    "rebuild",
    "backup",
    "project",
    "electron",
    "vue"
  ],
  "author": "Enco-shark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enco-shark/json-build.git"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.json-build.app",
    "productName": "JSON Build",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
